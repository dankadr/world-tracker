{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/admin/:path*", "destination": "/api" },
    { "source": "/nominatim/:path*", "destination": "https://nominatim.openstreetmap.org/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300,
      "excludeFiles": "{node_modules,dist,src,public,scripts,e2e,docs,.superpowers}/**"
    }
  },
  "crons": [
    { "path": "/api/cron/weekly-digest", "schedule": "0 9 * * 1" },
    { "path": "/api/cron/bucket-reminders", "schedule": "0 10 * * *" }
  ]
}
