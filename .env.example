# ──────────────────────────────────────────────────────────────
# Travel Tracker – Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then fill in the values below.

# ── Google OAuth ──────────────────────────────────────────────
# Get your Client ID from https://console.cloud.google.com/
# Create an OAuth 2.0 Client ID (Web application type).
# Add http://localhost:8088 to "Authorized JavaScript origins".
# For Vercel, also add your production URL (e.g. https://your-app.vercel.app).
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Vite requires the VITE_ prefix to expose env vars to the frontend at build time.
# On Vercel, set GOOGLE_CLIENT_ID and vite.config.js maps it automatically.
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# ── JWT ───────────────────────────────────────────────────────
# Random secret used to sign auth tokens. Change this in production!
# Generate one:  openssl rand -hex 32
JWT_SECRET=change-me-in-production

# ── Admin ─────────────────────────────────────────────────────
# Email address of the admin user (grants access to /admin/* endpoints).
ADMIN_EMAIL=your-email@example.com

# ── Database ──────────────────────────────────────────────────
# Docker Compose sets DATABASE_URL automatically; no action needed for local dev.
#
# For Vercel + Neon, set DATABASE_URL to the *pooled* connection string from
# your Neon dashboard (Settings → Connection Details → Pooled connection):
#   postgresql://user:pass@ep-xyz-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# Vercel's Neon integration auto-populates env vars with a project prefix, e.g.:
#   db_world_tracker_DATABASE_URL, db_world_tracker_POSTGRES_URL, etc.
# The backend checks both the standard names and the prefixed variants automatically.
# DATABASE_URL=

# ── Encryption ───────────────────────────────────────────────
# Master key used to encrypt sensitive DB columns (visited data, names, etc.).
# Generate one:  openssl rand -hex 32
# CRITICAL: Never change this after encrypting data — you won't be able to decrypt.
# On Vercel, set this in Project → Settings → Environment Variables.
ENCRYPTION_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────
# The frontend URL allowed to make cross-origin requests to the backend.
# In Vercel, set this to your production URL (e.g. https://your-app.vercel.app).
FRONTEND_URL=http://localhost:5173

# ── Secrets enforcement ───────────────────────────────────────
# Set to "true" to enforce that JWT_SECRET and ENCRYPTION_MASTER_KEY
# are not default placeholders. Always enabled on Vercel automatically.
# ENFORCE_SECRETS=true

# ── Sentry (optional) ────────────────────────────────────────
# Error tracking. Frontend uses VITE_SENTRY_DSN; backend uses SENTRY_DSN.
# Get a DSN from https://sentry.io/
# VITE_SENTRY_DSN=
# SENTRY_DSN=

# ── Email / Cron (optional) ──────────────────────────────────
# Resend API key for welcome emails, digests, and reminders.
# Get one from https://resend.com/
# RESEND_API_KEY=
#
# Optional override for the sender identity used in outgoing mail.
# EMAIL_FROM=World Tracker <noreply@worldtracker.app>
#
# Shared secret for scheduled cron endpoints. Invoke the cron routes with:
# Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=change-me-cron-secret
